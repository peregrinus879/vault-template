// Syncthing: do not sync git history or Syncthing versioning
.git
.stversions
// Per-device state (prevent sync conflicts and cross-device leakage)
.trash
.claude
// Syncthing conflict files (disposable; git also ignores them)
*.sync-conflict-*
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
