#!/bin/sh
# Headless pinentry for unattended GPG operations.
# Returns an empty passphrase automatically so gpg-agent never blocks
# on a terminal prompt. Used by the vault auto-commit timer.
#
# Install: cp self-hosting/pinentry-null ~/.local/bin/ && chmod +x ~/.local/bin/pinentry-null
# Configure: set `pinentry-program /home/<user>/.local/bin/pinentry-null` in ~/.gnupg/gpg-agent.conf
# Restart agent: gpgconf --kill gpg-agent

echo "OK Pleased to meet you"
while IFS= read -r cmd; do
  case "$cmd" in
    GETPIN) echo "D "; echo "OK" ;;
    BYE)    echo "OK closing connection"; exit 0 ;;
    *)      echo "OK" ;;
  esac
done
