#!/usr/bin/env bash
# Frontmatter filler. Delegates to .githooks/lib/normalize.py, which
# holds the single source of truth for frontmatter rules (see the
# module docstring and DESIGN.md §9).
#
# This hook collects staged markdown files under content directories
# (derived from .gitattributes filter=git-crypt rules) and runs the
# normalizer on each. Modified files are re-staged.
#
# Auto-commit safe: non-interactive, exits 0 on success, warns on
# malformed frontmatter but does not reject, so the hourly timer
# stays unblocked.

set -uo pipefail

VAULT="$(git rev-parse --show-toplevel)" || exit 0
cd "$VAULT" || exit 0

if ! command -v python3 >/dev/null 2>&1; then
  printf -- '[pre-commit] python3 not found; skipping normalization.\n' >&2
  exit 0
fi

# Derive content directories from .gitattributes so a new encrypted
# directory requires only one file edit (see AGENTS.md propagation).
# The \.md$ filter naturally excludes 6-assets (binary) and
# 5-templates (not listed in .gitattributes).
mapfile -t CONTENT_DIRS < <(awk '/filter=git-crypt/ {print $1}' "$VAULT/.gitattributes" | sed 's|/\*\*$||')
if [ "${#CONTENT_DIRS[@]}" -eq 0 ]; then
  exit 0
fi
printf -v CONTENT_DIRS_PIPE '%s|' "${CONTENT_DIRS[@]}"
CONTENT_DIRS_RE="^(${CONTENT_DIRS_PIPE%|})/.+\\.md\$"

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=AM | grep -E "$CONTENT_DIRS_RE" || true)
if [ "${#staged_files[@]}" -eq 0 ]; then
  exit 0
fi

# Track originals to detect which files the normalizer changed and
# re-stage only those.
changed=()
for f in "${staged_files[@]}"; do
  [ -f "$f" ] || continue
  before="$(sha1sum "$f" | awk '{print $1}')"
  if ! python3 "$VAULT/.githooks/lib/normalize.py" --fill --vault-root "$VAULT" "$f"; then
    printf -- '[pre-commit] normalize failed on %s; continuing.\n' "$f" >&2
    continue
  fi
  after="$(sha1sum "$f" | awk '{print $1}')"
  if [ "$before" != "$after" ]; then
    changed+=("$f")
    git add "$f"
  fi
done

if [ "${#changed[@]}" -gt 0 ]; then
  printf -- '[pre-commit] normalized %d file(s).\n' "${#changed[@]}" >&2
fi

exit 0
