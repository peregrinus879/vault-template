#!/usr/bin/env bash
# Sync public-facing vault files to the public template repo.
# Runs after every commit in the vault repo (including auto-commits).
#
# ENABLE: on the remote hub, run `git config core.hooksPath .githooks` once.
# FORK NOTE: set `git config vault.publicPath /path/to/your/vault-template`
# if your public mirror lives anywhere other than the default below.
#
# SAFETY MODEL: fail-closed allowlist. The rsync filter below names every
# path that may leave this repo. A new root file or a new non-content
# top-level directory will not publish unless its path is added explicitly.
# Content-directory contents are excluded by default because content dirs
# are never in the allowlist.
#
# Structural content dirs (0-fleeting, 1-literature, ..., 6-assets) are
# recreated in the public repo by the .gitkeep loop further down, so the
# public mirror shows the layout without any private content.

set -euo pipefail

# Resolve the vault root from the repo being committed, not from $HOME.
VAULT="$(git rev-parse --show-toplevel)"

# PUBLIC can be overridden per-repo via `git config vault.publicPath`;
# default is the canonical location on the remote hub.
PUBLIC="$(git -C "$VAULT" config vault.publicPath 2>/dev/null || echo "$HOME/projects/repos/templates/vault-template")"

# Bail if the public repo isn't cloned on this machine.
[ -d "$PUBLIC/.git" ] || exit 0

# Sentinel: refuse to publish unless $PUBLIC is the intended vault-template
# mirror. An errant or hostile vault.publicPath value pointing at any other
# git repo would otherwise expose it to rsync --delete, rm -rf, git add -A,
# commit, and push from this hook. The marker file lives in vault-template
# only (not in private vault) and is bootstrapped one-time per fork.
[ -f "$PUBLIC/.public-mirror-marker" ] || {
  printf -- '[post-commit] refusing: %s lacks .public-mirror-marker sentinel\n' "$PUBLIC" >&2
  exit 0
}

# Allowlist sync. First matching filter rule wins; the trailing --exclude='*'
# denies anything the allowlist did not name. Protect filters keep
# public-only files from being removed by --delete when the source lacks them.
rsync -a --delete \
  --filter='P /.public-mirror-marker' \
  \
  --include='/README.md' \
  --include='/WORKFLOW.md' \
  --include='/SETUP-LOCAL.md' \
  --include='/SETUP-HUB.md' \
  --include='/DESIGN.md' \
  --include='/AGENTS.md' \
  --include='/CLAUDE.md' \
  --include='/LICENSE' \
  --include='/.gitignore' \
  --include='/.gitattributes' \
  --include='/.stignore' \
  \
  --include='/nvim-vault/' \
  --include='/nvim-vault/**' \
  --include='/hub/' \
  --include='/hub/**' \
  --include='/5-templates/' \
  --include='/5-templates/**' \
  --include='/.githooks/' \
  --include='/.githooks/**' \
  \
  --include='/.obsidian/' \
  --include='/.obsidian/app.json' \
  --include='/.obsidian/appearance.json' \
  --include='/.obsidian/core-plugins.json' \
  --include='/.obsidian/graph.json' \
  --include='/.obsidian/templates.json' \
  --include='/.obsidian/snippets/' \
  --include='/.obsidian/snippets/**' \
  \
  --exclude='*' \
  \
  "$VAULT/" "$PUBLIC/"

# Derive content directories from .gitattributes (git-crypt rules).
# Used by the orphan cleanup and .gitkeep loop below to recreate the
# empty structural layout in the public mirror.
CONTENT_DIRS=()
while IFS= read -r line; do
  CONTENT_DIRS+=("${line%%/**}")
done < <(awk '/filter=git-crypt/ {print $1}' "$VAULT/.gitattributes")

# Clean orphaned directories: anything in the public repo root that is
# neither a content dir, infrastructure (.git, .obsidian), nor explicitly
# present in the vault. Guards against renamed/removed top-level items.
#
# COUPLING: the skip-list below must stay in sync with the rsync
# --include list at the top of this hook and with ALLOWED_ROOT_FILES.
# Any new non-content top-level directory or file added to the public
# mirror must be named in all three places; otherwise the cleanup
# below will delete it on every sync.
for dir in "$PUBLIC"/*/ "$PUBLIC"/.*/; do
  [ -d "$dir" ] || continue
  name="$(basename "$dir")"
  case "$name" in
    . | .. | .git | .obsidian | .githooks | nvim-vault | hub) continue ;;
  esac
  [ -d "$VAULT/$name" ] || rm -rf "$dir"
done

# Clean orphaned root files: rsync --delete only removes files within the
# included set. Files removed from the allowlist (excluded by --exclude='*')
# are invisible to rsync and left behind. This loop catches them.
# Keep in sync with the rsync --include list above.
ALLOWED_ROOT_FILES="README.md WORKFLOW.md SETUP-LOCAL.md SETUP-HUB.md DESIGN.md AGENTS.md CLAUDE.md LICENSE .gitignore .gitattributes .stignore .public-mirror-marker"
for file in "$PUBLIC"/* "$PUBLIC"/.*; do
  [ -f "$file" ] || continue
  name="$(basename "$file")"
  case " $ALLOWED_ROOT_FILES " in
    *" $name "*) ;;
    *) rm -f "$file" ;;
  esac
done

# Ensure each content directory exists in public with a .gitkeep,
# so the empty structural layout mirrors the vault.
for dir in "${CONTENT_DIRS[@]}"; do
  mkdir -p "$PUBLIC/$dir"
  [ -f "$PUBLIC/$dir/.gitkeep" ] || touch "$PUBLIC/$dir/.gitkeep"
done

# Themes are excluded from the public mirror by design: forks pick
# their own theme. The private vault may carry a local theme, but it
# must never reach vault-template. rsync cannot delete this since
# .obsidian/themes/ is no longer in the include list (rsync sees only
# what is included). Explicit cleanup here keeps the public mirror
# theme-free on every sync.
rm -rf "$PUBLIC/.obsidian/themes"

cd "$PUBLIC" || exit 1
git add -A

# Only commit and push if there are changes.
if ! git diff --cached --quiet; then
  git commit -m "sync: $(date +%F-%H%M)"
  # Rely on branch upstream tracking rather than hardcoded origin/main,
  # so the hook works in forks that name their remote or default branch
  # differently. Push errors go to stderr so they're visible in journal logs.
  git push --quiet || printf -- '[post-commit] push failed; next sync will retry\n' >&2
fi
